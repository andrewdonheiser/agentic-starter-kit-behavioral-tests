# Cluster type: "openshift" or "kind" (auto-detected if empty)
CLUSTER_TYPE=

# Shared (all demos)
API_KEY=
BASE_URL=
MODEL_ID=
# Required for OpenShift, not needed for kind
REGISTRY_PREFIX=quay.io/your-username

# agentic_rag
EMBEDDING_MODEL=
VECTOR_STORE_ID=
VECTOR_STORE_NAME=

# react_with_database_memory
# For kind: pre-configured (PostgreSQL deployed by kind-setup.sh) — leave blank
# For OpenShift: set to your external PostgreSQL instance
POSTGRES_HOST=
POSTGRES_PORT=5432
POSTGRES_DB=agent_memory
POSTGRES_USER=postgres
POSTGRES_PASSWORD=
